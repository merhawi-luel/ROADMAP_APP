// This is your Prisma schema file for RoadmapApp
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model - stores user authentication and profile information
model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  roadmaps      Roadmap[]
  playlist      PlaylistItem[]
  socialLinks   SocialLinks?
  plannerEntries PlannerEntry[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// Account model - OAuth accounts linked to users (NextAuth.js)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Session model - user sessions (NextAuth.js)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Roadmap model - learning roadmaps created by users
model Roadmap {
  id          String          @id @default(cuid())
  title       String
  description String          @db.Text
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       ChecklistItem[]
  progressSnapshots ProgressSnapshot[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId])
}

// ChecklistItem model - individual items in a roadmap (video, link, or task)
model ChecklistItem {
  id        String   @id @default(cuid())
  title     String
  type      String   // 'video' | 'link' | 'task'
  url       String?
  done      Boolean  @default(false)
  order     Int
  roadmapId String
  roadmap   Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  plannerEntries PlannerEntry[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roadmapId])
  @@index([done])
}

model ProgressSnapshot {
  id            String   @id @default(cuid())
  roadmapId     String
  roadmap       Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  totalItems    Int
  completedItems Int
  percentage    Int
  source        String   @default("system")
  createdAt     DateTime @default(now())

  @@index([roadmapId, createdAt])
}

// PlaylistItem model - user's music playlist for background listening
model PlaylistItem {
  id        String   @id @default(cuid())
  youtubeId String
  title     String
  thumbnail String
  order     Int
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

// SocialLinks model - user's social and coding platform profiles
model SocialLinks {
  id         String  @id @default(cuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedin   String?
  instagram  String?
  telegram   String?
  leetcode   String?
  codeforces String?
  github     String?
  x          String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// VerificationToken model - email verification tokens (NextAuth.js)
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// PlannerEntry model - daily/weekly planner entries
model PlannerEntry {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            String   // ISO date string YYYY-MM-DD
  title           String
  timeFrom        String?  // HH:MM e.g. "09:00"
  timeTo          String?  // HH:MM e.g. "11:00"
  notes           String?  @db.Text
  completed       Boolean  @default(false)
  checklistItemId String?
  checklistItem   ChecklistItem? @relation(fields: [checklistItemId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, date])
}
